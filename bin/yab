#!/bin/bash

# yab: A simple wrapper for installing aur packages from a list on Arch/Artix Linux.

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

set -e

info() {
    echo -e "$(date '+%H:%M:%S') ${BLUE}==> $1${NC}"
}

warn() {
    echo -e "$(date '+%H:%M:%S') ${YELLOW}==> $1${NC}
}

error() {
    echo -e "$(date '+%H:%M:%S') ${RED}==> $1${NC}" >&2
    log "[ERROR] $1"
}

# Help function
show_help() {
    echo "Usage: yab <file>"
    echo
    echo "Install a bundle of packages listed in <file>."
    echo "Packages should be one per line. Lines starting with # or containing # are ignored."
    echo
    echo "Options:"
    echo "  -h, --help    Show this help message"
    echo
    echo "Requirement:"
    echo "  This script must not be run with sudo."
}

# Check for help flag
if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    show_help
    exit 0
fi

# Check for file argument
if [ -z "$1" ]; then
    error "Error: No package list file provided."
    show_help
    exit 1
fi

FILE="$1"

if [ ! -f "$FILE" ]; then
    error "Error: File '$FILE' not found."
    exit 1
fi

# Parse file: remove comments and empty lines
PACKAGES=$(sed 's/#.*//; /^[[:space:]]*$/d' "$FILE")

if [ -z "$PACKAGES" ]; then
    warn "No valid packages found in $FILE."
    exit 0
fi

# Install packages
PACKAGES_ONELINE=$(echo $PACKAGES)
info "Installing packages: $PACKAGES_ONELINE"

yay -S $PACKAGES_ONELINE
